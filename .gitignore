# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# Environment and local secrets (never commit real keys)
.env
.env.*

# Certificates / keys
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
*.keystore

# Capacitor / native (when you add platforms)
**/android/.gradle
**/android/app/build
**/android/captures
**/android/local.properties
**/ios/Pods
**/ios/**/*.xcuserdata
**/ios/**/DerivedData

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.claude/worktrees
.claude/settings.local.json

.angular
